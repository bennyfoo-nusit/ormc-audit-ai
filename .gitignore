# AI-Assisted SDLC Framework
# .gitignore - Prevent sensitive files from being committed

# ==============================================================================
# SECURITY - CREDENTIALS AND SECRETS
# ==============================================================================
# NEVER commit these files!
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# ==============================================================================
# OPERATING SYSTEM FILES
# ==============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ==============================================================================
# IDE AND EDITOR FILES
# ==============================================================================
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
*.code-workspace

# JetBrains IDEs (IntelliJ, WebStorm, PyCharm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# ==============================================================================
# DEPENDENCY DIRECTORIES
# ==============================================================================
# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Python
__pycache__/
*.py[cod]
*$py.class
venv/
env/
ENV/
.venv
pip-log.txt
pip-delete-this-directory.txt

# Java
target/
*.class
*.jar
*.war
*.ear

# Ruby
.bundle/
vendor/bundle/

# ==============================================================================
# BUILD AND DISTRIBUTION
# ==============================================================================
# Build outputs
dist/
build/
out/
*.log

# Coverage reports
coverage/
*.lcov
.nyc_output/
htmlcov/
.coverage
.coverage.*

# ==============================================================================
# TEMPORARY AND CACHE FILES
# ==============================================================================
*.tmp
*.temp
*.cache
*.swp
*.swo
.cache/
.temp/

# ==============================================================================
# PROJECT-SPECIFIC (Generated by agents)
# ==============================================================================
# Keep the structure but ignore generated content in new projects
# Uncomment these if you want to ignore generated docs in derived projects
# docs/requirements/functional/*.md
# docs/requirements/non-functional/*.md
# docs/requirements/clarifications/*.md
# docs/planning/*.md

# Keep template files but ignore generated documentation
# Uncomment if needed:
# docs/operations/*.md
# docs/api/*.md

# ==============================================================================
# BACKUP FILES
# ==============================================================================
*.bak
*.backup
*.old
*_backup.*

# ==============================================================================
# LOGS
# ==============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ==============================================================================
# TESTING
# ==============================================================================
.pytest_cache/
.jest/
test-results/
playwright-report/

# ==============================================================================
# PROJECT FOLDERS
# ==============================================================================
prototype/
prototype1/
docs/*
!docs/adr/
!docs/design/
docs/design/*
!docs/design/DESIGN_PRINCIPLES.md
!docs/design/SPARKS_INSTRUCTION.md
.vite/

# ==============================================================================
# EVALUATION OUTPUTS
# ==============================================================================
docs/evaluation/

# ==============================================================================
# MISC
# ==============================================================================
.history/
*.sublime-workspace
