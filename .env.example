# AI-Assisted SDLC Framework - Environment Variables Template
# 
# IMPORTANT: 
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual tokens in .env (never commit .env to git!)
# 3. See .github/CREDENTIAL_SETUP.md for detailed setup instructions
#
# Token Generation URLs:
# - GitHub: https://github.com/settings/tokens
# - Azure DevOps: https://dev.azure.com/{your-org}/_usersSettings/tokens
# - Confluence: https://id.atlassian.com/manage-profile/security/api-tokens

# ==============================================================================
# GITHUB CONFIGURATION
# ==============================================================================
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, workflow, write:packages, read:org, project
GITHUB_TOKEN=

# Your GitHub repository (format: owner/repo-name)
# Example: my-org/my-project
GITHUB_REPOSITORY=

# ==============================================================================
# AZURE DEVOPS CONFIGURATION
# ==============================================================================
# Generate at: https://dev.azure.com/{your-org}/_usersSettings/tokens
# Required scopes: Work Items, Code, Build, Release, Project and Team, Graph, Test Management
AZURE_DEVOPS_TOKEN=

# Your Azure DevOps organization name (from URL: dev.azure.com/{org-name})
AZURE_DEVOPS_ORG=

# Your Azure DevOps project name
AZURE_DEVOPS_PROJECT=

# ==============================================================================
# CONFLUENCE CONFIGURATION
# ==============================================================================
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_TOKEN=

# Your Confluence site URL (example: https://yourcompany.atlassian.net/wiki)
CONFLUENCE_URL=

# Your Atlassian account email (used for authentication)
CONFLUENCE_EMAIL=

# Your Confluence space key (found in Space Settings)
# Example: PROJ, DEV, DOCS
CONFLUENCE_SPACE_KEY=

# ==============================================================================
# OPTIONAL: ADDITIONAL CONFIGURATION
# ==============================================================================

# Enable debug logging (true/false)
# DEBUG=false

# Default branch for repository
# DEFAULT_BRANCH=main

# Timezone for reporting
# TIMEZONE=UTC
